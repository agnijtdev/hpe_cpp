[req]
distinguished_name = req_distinguished_name
req_extensions     = v3_req
prompt             = no

[req_distinguished_name]
C  = BE
ST = Wallonia
O  = BGPoST-Lab
CN = replica-b.bgpost.lab

[v3_req]
subjectAltName = @alt_names
keyUsage       = digitalSignature, keyEncipherment
extendedKeyUsage = clientAuth, serverAuth

[alt_names]
DNS.1 = replica-b.bgpost.lab
IP.1  = 2001:db8:b::1

[v3_req_extra]
# BGPoST Router Configuration Section (paper Section 4 / Listing 1)
1.3.6.1.4.1.99999.1 = ASN1:UTF8String:{"anycast_prefix":"2001:db8:ff::/48","service":"dns","health_check":{"port":53,"protocol":"udp","query":"example.com","interval":10},"as_number":65102}
1.3.6.1.4.1.99999.1 = ASN1:UTF8String:{"anycast_prefix":"2001:db8:ff::/48","service":"dns","health_check":{"port":53,"protocol":"udp","query":"example.com","interval":10},"as_number":65102}
