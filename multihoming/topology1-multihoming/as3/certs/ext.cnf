[req]
distinguished_name = req_distinguished_name
req_extensions     = v3_req
prompt             = no

[req_distinguished_name]
C  = BE
ST = Wallonia
O  = BGPoST-Lab
CN = as3.bgpost.lab

[v3_req]
subjectAltName = @alt_names
keyUsage       = digitalSignature, keyEncipherment
extendedKeyUsage = clientAuth, serverAuth

[alt_names]
DNS.1 = as3.bgpost.lab
IP.1  = 2001:db8:23::2

[v3_req_extra]
# BGPoST Router Configuration Section (paper Section 4 / Listing 1)
1.3.6.1.4.1.99999.1 = ASN1:UTF8String:{"prefixes":["2001:db8:3::/48"],"tunnel":{"type":"GRE","local_addr":"2001:db8:23::2","remote_addr":"2001:db8:23::1","backup_via":"2001:db8:13::1","keepalive_interval":5,"bfd":true},"as_number":65003}
